# e2e-verify manifest — consumed by ~/Hermes/bin/e2e-verify
# Registers this project for the host e2e verification loop.
MODE=http
PORT=${APP_PORT:-8010}
BOARD=sd-google-docs-backend-mvp-v2026.07.02.2
UP=docker compose up -d --wait
DOWN=docker compose down --volumes
READY=curl -sf http://localhost:${APP_PORT:-8010}/healthz
LOGS=docker compose logs --tail=50
TEST_DEPS=httpx pytest websockets pytest-asyncio
ACCEPTANCE=pytest verify/acceptance/ -v
