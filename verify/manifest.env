# e2e-verify manifest — consumed by ~/Hermes/bin/e2e-verify
# Source: set -a; . verify/manifest.env  (allexport + source)
# All multi-word values MUST be single-quoted to survive word-splitting
# during `set -a; . manifest.env`.

MODE=http
PORT=${PORT:-8010}
BOARD=sd-google-docs-backend-mvp-v2026.07.02.2
UP=docker compose up -d --wait
DOWN=docker compose down --volumes
READY=curl -sf http://localhost:${PORT}/healthz
LOGS='docker compose logs --tail=50'
TEST_DEPS='httpx pytest websockets pytest-asyncio'
ACCEPTANCE='API_BASE_URL=http://localhost:${PORT} pytest verify/acceptance/ -v'
