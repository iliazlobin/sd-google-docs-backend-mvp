# ── Google Docs MVP — Environment Variables ──────────────────────────────
# All keys are commented-out so a bare `cp .env.example .env` never injects
# empty values into pydantic-settings typed fields. Uncomment and set to
# override the defaults below.
#
# Settings are loaded by pydantic-settings (src/googledocs/config.py) from
# the local .env file. Docker Compose also reads .env for variable
# substitution in docker-compose.yml.
#
# In-container defaults in docker-compose.yml point to the compose network
# (db:5432, redis:6379) — you generally don't need to set these in .env
# unless you're running outside compose or need to override compose behavior.

# Database URL (asyncpg driver)
# Format: postgresql+asyncpg://user:password@host:port/dbname
# In compose: postgresql+asyncpg://googledocs:googledocs@db:5432/googledocs
#DB_URL=

# Redis URL
# Format: redis://host:port/db
# In compose: redis://redis:6379/0
#REDIS_URL=

# Host port for the app container (Compose variable substitution)
# The app listens on :8000 inside the container; this maps it to the host.
#APP_PORT=
